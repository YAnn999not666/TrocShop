{
  "id": "com.trocshop.app",
  "name": "TrocShop - Échangez et Vendez",
  "short_name": "TrocShop",
  "description": "Plateforme moderne d'échange et de vente d'articles entre particuliers à Yamoussoukro, Côte d'Ivoire.",
  "lang": "fr-CI",
  "dir": "ltr",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "minimal-ui", "standalone"],
  "orientation": "portrait",
  "background_color": "#FFFFFF",
  "theme_color": "#EA580C",
  "categories": ["shopping", "lifestyle", "business"],
  "iarc_rating_id": "00000000-0000-0000-0000-000000000000",
  "icons": [
    {
      "src": "/icon.jpg",
      "sizes": "48x48 72x72 96x96 128x128 144x144 152x152 192x192 384x384 512x512",
      "type": "image/jpeg",
      "purpose": "any"
    },
    {
      "src": "/icon.jpg",
      "sizes": "192x192 512x512",
      "type": "image/jpeg",
      "purpose": "maskable"
    },
    {
      "src": "/icon.jpg",
      "sizes": "512x512",
      "type": "image/jpeg",
      "purpose": "monochrome"
    }
  ],
  "screenshots": [
    {
      "src": "/icon.jpg",
      "sizes": "1024x1024",
      "type": "image/jpeg",
      "form_factor": "wide",
      "label": "Interface Tablette TrocShop"
    },
    {
      "src": "/icon.jpg",
      "sizes": "512x512",
      "type": "image/jpeg",
      "form_factor": "narrow",
      "label": "Interface Mobile TrocShop"
    }
  ],
  "shortcuts": [
    {
      "name": "Publier une annonce",
      "short_name": "Vendre",
      "url": "/?tab=sell",
      "icons": [{ "src": "/icon.jpg", "sizes": "192x192", "type": "image/jpeg" }]
    },
    {
      "name": "Mes messages",
      "short_name": "Messages",
      "url": "/?tab=messages",
      "icons": [{ "src": "/icon.jpg", "sizes": "192x192", "type": "image/jpeg" }]
    }
  ],
  "share_target": {
    "action": "/",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "file_handlers": [
    {
      "action": "/",
      "accept": {
        "image/*": [".jpg", ".jpeg", ".png", ".webp"]
      }
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+trocshop",
      "url": "/?type=%s"
    }
  ],
  "launch_handler": {
    "client_mode": "focus-existing"
  },
  "note_taking": {
    "new_note_url": "/?action=new-note"
  },
  "widgets": [
    {
      "name": "TrocShop Statistiques",
      "description": "Widget pour voir vos échanges récents",
      "tag": "stats",
      "ms_ac_template": "/widget-template.json",
      "data": "/widget-data.json",
      "type": "application/json",
      "icons": [
        {
          "src": "/icon.jpg",
          "sizes": "192x192",
          "type": "image/jpeg"
        }
      ]
    }
  ],
  "edge_side_panel": {
    "preferred_width": 400
  },
  "scope_extensions": [
    {
      "origin": "*.trocshop.app"
    }
  ],
  "prefer_related_applications": false,
  "related_applications": []
}
