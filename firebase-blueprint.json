{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Extended user profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "phoneVisibility": { "type": "string", "enum": ["public", "private"] },
        "neighborhood": { "type": "string" },
        "city": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "coverURL": { "type": "string" },
        "bio": { "type": "string" },
        "location": { "type": "string" },
        "createdAt": { "type": "number" },
        "rating": { "type": "number" },
        "reviewCount": { "type": "number" },
        "notificationsEnabled": { "type": "boolean" }
      },
      "required": ["uid", "displayName", "email", "createdAt"]
    },
    "Product": {
      "title": "Marketplace Listing",
      "description": "A product listed for sale or exchange.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "condition": { "type": "string", "enum": ["Neuf", "Très bon état", "Bon état", "Satisfaisant"] },
        "category": { "type": "string" },
        "neighborhood": { "type": "string" },
        "listingType": { "type": "string", "enum": ["sale", "troc", "mixed"] },
        "exchangeWanted": { "type": "string" },
        "canTravel": { "type": "boolean" },
        "meetingPoint": { "type": "string" },
        "availability": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string", "format": "uri" } },
        "sellerId": { "type": "string" },
        "sellerName": { "type": "string" },
        "status": { "type": "string", "enum": ["available", "pending", "sold", "reserved"] },
        "is_available": { "type": "boolean" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" },
        "likesCount": { "type": "number" }
      },
      "required": ["title", "description", "price", "category", "sellerId", "status", "createdAt"]
    },
    "Review": {
      "title": "User or Product Review",
      "description": "A rating and comment left by a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fromUserId": { "type": "string" },
        "fromUserName": { "type": "string" },
        "toUserId": { "type": "string" },
        "toProductId": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["fromUserId", "rating", "comment", "createdAt"]
    },
    "Conversation": {
      "title": "Chat Conversation",
      "description": "A chat thread between a buyer and a seller.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "participantIds": { "type": "array", "items": { "type": "string" } },
        "productId": { "type": "string" },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "number" }
      },
      "required": ["participantIds", "productId", "updatedAt"]
    },
    "Message": {
      "title": "Chat Message",
      "description": "A single message in a conversation.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["senderId", "text", "createdAt"]
    },
    "Exchange": {
      "title": "Exchange Transaction",
      "description": "Record of a trade or purchase.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "productTitle": { "type": "string" },
        "productImage": { "type": "string" },
        "buyerId": { "type": "string" },
        "sellerId": { "type": "string" },
        "exchangeProductId": { "type": "string" },
        "exchangeProductIds": { "type": "array", "items": { "type": "string" } },
        "priceAdjustment": { "type": "number" },
        "trocCode": { "type": "string" },
        "type": { "type": "string", "enum": ["purchase", "exchange"] },
        "status": { "type": "string", "enum": ["pending", "accepted", "completed", "cancelled"] },
        "buyerRating": { "type": "number" },
        "sellerRating": { "type": "number" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["productId", "buyerId", "sellerId", "type", "status", "createdAt"]
    },
    "Notification": {
      "title": "App Notification",
      "description": "Alert for a user about activity.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["message", "favorite", "comment", "troc", "transaction"] },
        "title": { "type": "string" },
        "body": { "type": "string" },
        "toUserId": { "type": "string" },
        "fromUserId": { "type": "string" },
        "fromUserName": { "type": "string" },
        "productId": { "type": "string" },
        "conversationId": { "type": "string" },
        "transactionId": { "type": "string" },
        "createdAt": { "type": "number" },
        "read": { "type": "boolean" }
      },
      "required": ["type", "title", "body", "toUserId", "createdAt", "read"]
    },
    "Transaction": {
      "title": "Direct Purchase Transaction",
      "description": "Workflow for buying a product via chat.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "productTitle": { "type": "string" },
        "buyerId": { "type": "string" },
        "sellerId": { "type": "string" },
        "participantIds": { "type": "array", "items": { "type": "string" } },
        "price": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "code_generated", "completed", "cancelled"] },
        "verificationCode": { "type": "string" },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" },
        "buyerRated": { "type": "boolean" },
        "sellerRated": { "type": "boolean" }
      },
      "required": ["productId", "buyerId", "sellerId", "participantIds", "status", "createdAt"]
    },
    "AppConfig": {
      "title": "Application Configuration",
      "description": "Global application configuration documents.",
      "type": "object",
      "properties": {
        "version": { "type": "string" },
        "downloadUrl": { "type": "string" }
      },
      "required": ["version"]
    }
  },
  "firestore": {
    "appConfig": {
      "schema": "AppConfig",
      "description": "Global application configuration documents such as active version."
    },
    "users": {
      "schema": "User",
      "description": "Users of the marketplace."
    },
    "users/{userId}/notifications": {
      "schema": "Notification",
      "description": "User specific notifications."
    },
    "products": {
      "schema": "Product",
      "description": "All listings in the marketplace."
    },
    "reviews": {
      "schema": "Review",
      "description": "User and product reviews."
    },
    "conversations": {
      "schema": "Conversation",
      "description": "Messaging threads."
    },
    "conversations/{convId}/messages": {
      "schema": "Message",
      "description": "Messages within a conversation."
    },
    "exchanges": {
      "schema": "Exchange",
      "description": "History of trades and purchases."
    },
    "transactions": {
      "schema": "Transaction",
      "description": "Direct purchase workflows from chat."
    }
  }
}
